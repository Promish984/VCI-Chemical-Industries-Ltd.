{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Represents a chemical or carbon product manufactured by the company.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the product" },
        "categoryId": { "type": "string", "description": "ID of the category this product belongs to" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "number", "description": "Server timestamp" },
        "updatedAt": { "type": "number", "description": "Server timestamp" }
      },
      "required": ["name", "categoryId", "description", "createdAt", "updatedAt"]
    },
    "Category": {
      "title": "Category",
      "description": "A category grouping products.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "createdAt"]
    },
    "ContactInquiry": {
      "title": "Contact Inquiry",
      "description": "A message submitted through the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "number" },
        "status": { "type": "string", "enum": ["new", "read", "replied"] }
      },
      "required": ["name", "email", "message", "createdAt", "status"]
    },
    "Career": {
      "title": "Career / Job Listing",
      "description": "Open job positions at the company.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "description", "status", "createdAt", "updatedAt"]
    },
    "AdminConfig": {
      "title": "Admin Config",
      "description": "Information about admin users for RBAC.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Collection of products that the company offers"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Categories for grouping products"
    },
    "/contactInquiries/{inquiryId}": {
      "schema": { "$ref": "#/entities/ContactInquiry" },
      "description": "Submissions from the public contact form"
    },
    "/careers/{careerId}": {
      "schema": { "$ref": "#/entities/Career" },
      "description": "Available career opportunities"
    },
    "/admins/{userId}": {
      "schema": { "$ref": "#/entities/AdminConfig" },
      "description": "List of user IDs (and emails) that have admin privileges"
    }
  }
}
